---
import DefaultHeader from '@astrojs/starlight/components/Header.astro'

const DOCS_ENABLE_NATIVE_TAB = process.env.DOCS_ENABLE_NATIVE_TAB === '1'

const baseUrl = import.meta.env.BASE_URL || '/'
const pathname = Astro.url.pathname

function withBase(path: string): string {
  const base = baseUrl === '/' ? '' : baseUrl.replace(/\/$/, '')
  return `${base}${path}`
}

function withoutBase(path: string): string {
  if (baseUrl === '/') return path
  const base = baseUrl.replace(/\/$/, '')
  if (!path.startsWith(base)) return path
  const stripped = path.slice(base.length)
  return stripped.startsWith('/') ? stripped : `/${stripped}`
}

const normalizedPath = withoutBase(pathname)

const tabs = [
  { key: 'guides', label: 'Guides', href: withBase('/guides'), visible: true },
  { key: 'core', label: 'Core', href: withBase('/core'), visible: true },
  { key: 'web', label: 'Web', href: withBase('/web'), visible: true },
  { key: 'native', label: 'Native', href: withBase('/native'), visible: DOCS_ENABLE_NATIVE_TAB },
  { key: 'integrations', label: 'Integrations', href: withBase('/integrations'), visible: true },
].filter(tab => tab.visible)

function isActiveTab(key: string): boolean {
  return normalizedPath === `/${key}` || normalizedPath.startsWith(`/${key}/`)
}
---

<DefaultHeader />

<nav class="category-mobile" aria-label="Documentation categories">
  {tabs.map(tab => (
    <a class:list={{ 'mobile-tab': true, active: isActiveTab(tab.key) }} href={tab.href}>
      {tab.label}
    </a>
  ))}
</nav>

<nav class="category-inline" aria-label="Documentation categories">
  {tabs.map(tab => (
    <a class:list={{ tab: true, active: isActiveTab(tab.key) }} href={tab.href}>
      {tab.label}
    </a>
  ))}
</nav>

<script is:inline>
  (() => {
    const mount = document.querySelector('header .right-group')
    const nav = document.querySelector('header .category-inline')
    if (!mount || !nav) return

    const socialIcons = mount.querySelector('.social-icons')
    mount.insertBefore(nav, socialIcons ?? mount.firstChild)

    const header = document.querySelector('header')
    const mobileNav = document.querySelector('.category-mobile')
    if (header && mobileNav) {
      header.after(mobileNav)
    }
  })()
</script>

<style>
  .category-inline {
    align-items: center;
    display: none;
    gap: 0.375rem;
    margin-right: 0.75rem;
  }

  :global(header .right-group) .category-inline {
    display: inline-flex;
  }

  .tab {
    border: 1px solid var(--sl-color-hairline-light);
    border-radius: 999px;
    color: var(--sl-color-gray-2);
    font-size: 0.75rem;
    font-weight: 600;
    line-height: 1;
    padding: 0.375rem 0.625rem;
    text-decoration: none;
    transition: border-color 0.2s ease, color 0.2s ease, background-color 0.2s ease;
    white-space: nowrap;
  }

  .tab:hover {
    border-color: var(--sl-color-accent-high);
    color: var(--sl-color-accent-high);
  }

  .tab.active {
    background-color: var(--sl-color-accent-low);
    border-color: var(--sl-color-accent);
    color: var(--sl-color-accent-high);
  }

  @media (max-width: 80rem) {
    :global(header .right-group) .category-inline {
      display: none;
    }

    .category-mobile {
      display: flex;
    }
  }

  .category-mobile {
    align-items: center;
    border-bottom: 1px solid var(--sl-color-hairline-light);
    display: none;
    gap: 0.5rem;
    overflow-x: auto;
    padding: 0.5rem var(--sl-content-pad-x, 1rem);
    scrollbar-width: none;
  }

  .category-mobile::-webkit-scrollbar {
    display: none;
  }

  .mobile-tab {
    border: 1px solid var(--sl-color-hairline-light);
    border-radius: 999px;
    color: var(--sl-color-gray-2);
    font-size: 0.75rem;
    font-weight: 600;
    line-height: 1;
    padding: 0.375rem 0.625rem;
    text-decoration: none;
    transition: border-color 0.2s ease, color 0.2s ease, background-color 0.2s ease;
    white-space: nowrap;
  }

  .mobile-tab:hover {
    border-color: var(--sl-color-accent-high);
    color: var(--sl-color-accent-high);
  }

  .mobile-tab.active {
    background-color: var(--sl-color-accent-low);
    border-color: var(--sl-color-accent);
    color: var(--sl-color-accent-high);
  }
</style>
