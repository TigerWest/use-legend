---
import Default from "@astrojs/starlight/components/MarkdownContent.astro";
import { marked } from "marked";

const { description, sourceFile } = Astro.locals.starlightRoute.entry.data;
---

<Default
  >{
    description && sourceFile && <p set:html={marked.parse(description)} class="page-description" />
  }<slot /></Default
>
