---
import { Code } from "astro/components";
import { LinkButton } from "@astrojs/starlight/components";
import TimerWidget from "../demos/CounterDemo";

const { data } = Astro.locals.starlightRoute.entry;
const { title = data.title, tagline, actions = [] } = data.hero || {};

const hookCode = `import { useInterval } from '@usels/core'
import { useRef } from "react"

function Timer() {
  const count$ = useInterval(1000)
  const renders = useRef(0);
  renders.current += 1;

  return (
    <div>
      <div>{count$.get()}s</div>
      <div>renders: {renders.current}</div>
    </div>
  )
}`;

const scopeCode = `import { createInterval, createRef$ } from '@usels/core'

function Timer() {
  "use scope"
  const count$ = createInterval(1000)
  const renders$ = createRef$(0);
  renders$.current += 1;

  return (
    <div>
      <div>{count$.get()}s</div>
      <div>renders: {renders$.get()}</div>
    </div>
  )
}`;
---

<div
  class="grid items-center gap-16 pb-4 min-[50rem]:grid-cols-[5fr_5fr] min-[50rem]:gap-[4%] min-[50rem]:py-[clamp(2.5rem,calc(1rem+10vmin),10rem)]"
>
  <!-- Right column: code block + live widget overlay -->
  <div class="not-content order-2 w-[min(95%,25rem)] mx-auto min-[50rem]:w-full">
    <div class="relative rounded-2xl shadow-[0_25px_50px_-12px_rgba(0,0,0,0.5)] demo-wrapper">
      <div
        class="absolute top-2 left-2 z-10 flex gap-0.5 rounded-lg border border-white/10 bg-white/5 p-0.5"
        id="hero-tabs"
      >
        <button
          id="hero-tab-hook"
          class="rounded-md px-2.5 py-1 text-[10px] font-bold leading-none transition-colors bg-white/15 text-white cursor-pointer"
          >hook</button
        >
        <button
          id="hero-tab-scope"
          class="rounded-md px-2.5 py-1 text-[10px] font-bold leading-none transition-colors text-white/30 hover:text-white/50 cursor-pointer"
          >scope</button
        >
      </div>
      <div class="code-stack">
        <div id="hero-code-hook">
          <Code
            code={hookCode}
            lang="tsx"
            class="px-7 p-10 sm:px-10 text-xs rounded-md md:text-sm"
          />
        </div>
        <div id="hero-code-scope" style="visibility:hidden">
          <Code
            code={scopeCode}
            lang="tsx"
            class="px-5 p-10 sm:px-10 text-xs rounded-md md:text-sm"
          />
        </div>
      </div>
      <div class="absolute -bottom-12 right-0 sm:-bottom-16 sm:-right-4">
        <TimerWidget client:load />
      </div>
    </div>
  </div>

  <!-- Left column: title / tagline / actions -->
  <div
    class="flex flex-col gap-[clamp(1.5rem,calc(1.5rem+1vw),2rem)] text-center min-[50rem]:text-start"
  >
    <div class="flex flex-col gap-4 items-center [&>*]:max-w-[50ch] min-[50rem]:items-start">
      <h1
        id="_top"
        data-page-title
        set:html={title}
        class="text-[clamp(var(--sl-text-3xl),calc(0.25rem+5vw),var(--sl-text-6xl))] leading-[var(--sl-line-height-headings)] font-semibold text-[var(--sl-color-white)]"
      />
      {
        tagline && (
          <div
            class="text-[clamp(var(--sl-text-base),calc(0.0625rem+2vw),var(--sl-text-xl))] text-[var(--sl-color-gray-2)]"
            set:html={tagline}
          />
        )
      }
    </div>
    {
      actions.length > 0 && (
        <div class="flex gap-x-8 gap-y-4 flex-wrap justify-center min-[50rem]:justify-start">
          {actions.map(
            ({ attrs: { class: className, ...attrs } = {}, icon, link: href, text, variant }) => (
              <LinkButton {href} {variant} icon={icon?.name} class:list={[className]} {...attrs}>
                {text}
                {icon?.html && <Fragment set:html={icon.html} />}
              </LinkButton>
            )
          )}
        </div>
      )
    }
  </div>
</div>

<script>
  const hookTab = document.getElementById("hero-tab-hook");
  const scopeTab = document.getElementById("hero-tab-scope");
  const hookEl = document.getElementById("hero-code-hook");
  const scopeEl = document.getElementById("hero-code-scope");

  function setMode(isHook: boolean) {
    if (!hookEl || !scopeEl || !hookTab || !scopeTab) return;
    hookEl.style.visibility = isHook ? "" : "hidden";
    scopeEl.style.visibility = isHook ? "hidden" : "";
    hookTab.className = hookTab.className
      .replace(/bg-white\/15 text-white|text-white\/30 hover:text-white\/50/g, "")
      .trimEnd();
    scopeTab.className = scopeTab.className
      .replace(/bg-white\/15 text-white|text-white\/30 hover:text-white\/50/g, "")
      .trimEnd();
    hookTab.className += isHook ? " bg-white/15 text-white" : " text-white/30 hover:text-white/50";
    scopeTab.className += isHook ? " text-white/30 hover:text-white/50" : " bg-white/15 text-white";
  }

  hookTab?.addEventListener("click", () => {
    setMode(true);
    window.dispatchEvent(new CustomEvent("hero-mode-change", { detail: { isHook: true } }));
  });
  scopeTab?.addEventListener("click", () => {
    setMode(false);
    window.dispatchEvent(new CustomEvent("hero-mode-change", { detail: { isHook: false } }));
  });
</script>

<style>
  @layer starlight.core {
    /* strip expressive-code chrome to look embedded */
    .demo-wrapper :global(.expressive-code) {
      --ec-brdRad: 1rem;
    }

    .code-stack {
      display: grid;
    }
    .code-stack > * {
      grid-area: 1 / 1;
    }

    @media (max-width: 640px) {
      .demo-wrapper :global(.expressive-code pre) {
        white-space: pre-wrap;
        word-break: break-all;
      }
    }
  }
</style>
