---
import ObservableFirstDemo from "./ObservableFirstDemo";
import demoSource from "./ObservableFirstDemo.tsx?raw";
import { Code } from "astro/components";
---

<div class="not-content mt-3 mb-4">
  <ObservableFirstDemo client:load />
</div>

<details class="mt-2 overflow-hidden rounded-xl border border-sl-border bg-sl-surface">
  <summary class="cursor-pointer list-none select-none px-4 py-3 font-semibold [&::-webkit-details-marker]:hidden">
    Show code
  </summary>
  <div class="overflow-auto border-t border-sl-border [&_pre]:m-0 [&_pre]:rounded-none">
    <Code
      code={demoSource}
      lang="tsx"
      themes={{ light: "github-dark", dark: "github-dark" }}
      defaultColor="dark"
      wrap={false}
    />
  </div>
</details>
