{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"],
  "compilerOptions": {
    "paths": {
      "@demos/core/*": ["../packages/core/src/*"],
      "@demos/integrations/*": ["../packages/integrations/src/*"],
      "@browser/*": ["../packages/core/src/browser/*"],
      "@elements/*": ["../packages/core/src/elements/*"],
      "@reactivity/*": ["../packages/core/src/reactivity/*"],
      "@sensors/*": ["../packages/core/src/sensors/*"],
      "@shared": ["../packages/core/src/shared/index.ts"],
      "@shared/*": ["../packages/core/src/shared/*"],
      "@timer/*": ["../packages/core/src/timer/*"],
      "@utilities/*": ["../packages/core/src/utilities/*"],
      "@components/*": ["../packages/core/src/components/*"]
    }
  }
}
