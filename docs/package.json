{
  "name": "docs",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "pnpm dev:off",
    "dev:full": "DOCS_FAST_DEV=1 DOCS_ENABLE_TWOSLASH=0 DOCS_WARMUP_MODE=full tsx scripts/collect-docs.ts && astro dev --host",
    "dev:off": "DOCS_FAST_DEV=1 DOCS_ENABLE_TWOSLASH=0 DOCS_WARMUP_MODE=off tsx scripts/collect-docs.ts && astro dev --host",
    "start": "tsx scripts/collect-docs.ts && astro dev",
    "build": "tsx scripts/collect-docs.ts && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "collect-docs": "tsx scripts/collect-docs.ts",
    "twoslash:check": "tsx scripts/check-twoslash.ts"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.0.0",
    "@astrojs/react": "^4.0.0",
    "@astrojs/starlight": "^0.37.6",
    "@astrojs/starlight-tailwind": "^4.0.2",
    "@catppuccin/starlight": "^1.1.1",
    "@legendapp/state": "^2.1.15",
    "@tailwindcss/vite": "^4.2.1",
    "@usels/core": "workspace:*",
    "@usels/integrations": "workspace:*",
    "@usels/tanstack-query": "workspace:*",
    "@usels/web": "workspace:*",
    "astro": "^5.6.1",
    "es-toolkit": "^1.0.0",
    "expressive-code-twoslash": "^0.5.3",
    "marked": "^17.0.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.34.2",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@babel/core": "^7.0.0",
    "@usels/babel-plugin": "workspace:*",
    "@usels/vite-plugin": "workspace:*",
    "chokidar": "^4.0.3",
    "concurrently": "^9.1.0",
    "gray-matter": "^4.0.3",
    "tsx": "^4.19.2",
    "twoslash": "^0.2.12",
    "typescript": "^5.0.0"
  }
}
