{
  "name": "@usels/web",
  "version": "0.11.0",
  "description": "Browser-specific hooks for Legend-State",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.mjs",
  "types": "./dist/esm/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.mts",
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.js"
    },
    "./*": {
      "types": "./dist/esm/*.d.mts",
      "import": "./dist/esm/*.mjs",
      "require": "./dist/cjs/*.js"
    }
  },
  "dependencies": {
    "es-toolkit": "^1.0.0"
  },
  "scripts": {
    "build": "rimraf dist && tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:browser": "vitest --config vitest.browser.config.ts --run",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist node_modules"
  },
  "peerDependencies": {
    "@legendapp/state": "^3.0.0-beta.44",
    "@usels/core": "^0.9.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@legendapp/state": "3.0.0-beta.44",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@usels/core": "workspace:*",
    "@vitest/browser": "^4.0.18",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-istanbul": "^4.0.18",
    "esbuild-fix-imports-plugin": "^1.0.23",
    "jsdom": "^25.0.0",
    "playwright": "^1.58.2",
    "rimraf": "^5.0.0",
    "tsc-alias": "^1.8.16",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "keywords": [
    "legendapp",
    "legend-state",
    "utilities",
    "hooks",
    "browser"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
