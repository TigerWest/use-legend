{
  "name": "@usels/babel-plugin",
  "version": "0.11.1",
  "description": "Babel plugin for use-legend JSX Memo and use scope transforms",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.mjs",
  "types": "./dist/esm/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.mts",
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.js"
    }
  },
  "scripts": {
    "build": "rimraf dist && tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist node_modules"
  },
  "peerDependencies": {
    "@babel/core": ">=7.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/plugin-syntax-jsx": "^7.24.0",
    "@babel/types": "^7.24.0",
    "@types/babel__core": "^7.20.0",
    "babel-plugin-tester": "^11.0.4",
    "rimraf": "^5.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.2.2"
  }
}
