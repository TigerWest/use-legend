{
  "extends": "../../tsconfig.base.json",
  "include": ["src"],
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "jsx": "react-jsx",
    "baseUrl": "./src",
    "paths": {
      "@elements/*": ["elements/*"],
      "@state/*": ["state/*"],
      "@reactivity/*": ["reactivity/*"],
      "@shared": ["shared/index.ts"],
      "@shared/*": ["shared/*"],
      "@timer/*": ["timer/*"],
      "@utilities/*": ["utilities/*"],
      "@components/*": ["components/*"],
      "@sync/*": ["sync/*"],
      "@observe/*": ["observe/*"]
    }
  }
}
