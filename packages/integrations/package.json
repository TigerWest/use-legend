{
  "name": "@usels/integrations",
  "version": "0.7.0",
  "description": "Lightweight single-hook integrations for Legend-State",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:browser": "echo 'skip'",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "legendapp",
    "state",
    "integrations",
    "observable",
    "reactive"
  ],
  "dependencies": {
    "@usels/core": "workspace:*"
  },
  "peerDependencies": {
    "@legendapp/state": "^2.0.0 || ^3.0.0-beta.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "@legendapp/state": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@legendapp/state": "3.0.0-beta.44",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^25.3.3",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^25.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^4.0.18"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  }
}
