{
  "name": "@usels/tanstack-query",
  "version": "0.11.2",
  "description": "Observable-native TanStack Query integration for Legend-State",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.mjs",
  "types": "./dist/esm/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.mts",
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.js"
    }
  },
  "scripts": {
    "build": "rimraf dist && tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:browser": "vitest --config vitest.browser.config.ts --run",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist node_modules"
  },
  "keywords": [
    "legendapp",
    "state",
    "tanstack-query",
    "react-query",
    "observable",
    "reactive"
  ],
  "dependencies": {
    "@tanstack/query-core": "^5.90.20"
  },
  "peerDependencies": {
    "@usels/core": "^0.9.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@tanstack/query-core": "^5.90.20",
    "@tanstack/react-query": "^5.60.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^25.3.3",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@usels/core": "workspace:*",
    "@vitest/browser": "^4.0.18",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-istanbul": "^4.0.18",
    "esbuild-fix-imports-plugin": "^1.0.23",
    "jsdom": "^25.0.0",
    "playwright": "^1.58.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rimraf": "^5.0.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^4.0.18"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  }
}
